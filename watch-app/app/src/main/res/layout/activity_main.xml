<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:id="@+id/dataArea"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/alertArea">

        <com.heatstress.watch.VitalsPanelView
            android:id="@+id/vitalsPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/monitor_content_description" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/alertArea"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:background="#101116"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAlert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text=""
                android:textColor="#FF1744"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvAdvice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="2"
                android:text="@string/monitor_starting"
                android:textColor="#00E676"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnBind"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="#2266AA"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="绑定"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</RelativeLayout>
